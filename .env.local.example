NEXT_PUBLIC_SANITY_PROJECT_ID=eygp4ux2
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-07-12
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Only needed once draft-mode/live-preview (SHU-026) is implemented.
SANITY_API_READ_TOKEN=

# Needed to run `pnpm seed` (SHU-032) AND, in every deployed environment,
# for the contact form's Server Action (SHU-014) to write enquiry
# documents to Sanity — missing this crashes any request that touches it,
# not just the seed script. Generate a write-scoped token at
# manage.sanity.io — never commit a real value here.
SANITY_API_WRITE_TOKEN=
